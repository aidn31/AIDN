# AIDN Production Environment Configuration
# Copy this file to .env for production deployment

# Database
DB_PASSWORD=aidn_secure_production_password_change_me
DATABASE_URL=postgresql://aidn_user:${DB_PASSWORD}@postgres:5432/aidn_production

# API Keys (Set these to your actual values)
OPENAI_API_KEY=your_openai_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# LiveKit Configuration
LIVEKIT_URL=wss://your-livekit-server.livekit.io
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO

# Security
JWT_SECRET_KEY=generate_a_secure_random_jwt_secret_key_here
CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# Monitoring
GRAFANA_PASSWORD=secure_grafana_password_change_me

# Redis (Optional, for scaling)
REDIS_URL=redis://redis:6379/0

# External Services
SMTP_SERVER=your_smtp_server_here
SMTP_USERNAME=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here

# File Storage (for lead uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_BUCKET=your-aidn-uploads-bucket