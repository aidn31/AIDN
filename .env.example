# AIDN Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it contains secrets)

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/aidn

# AI Services
OPENAI_API_KEY=sk-your-openai-key-here
DEEPGRAM_API_KEY=your-deepgram-key-here
CARTESIA_API_KEY=sk_car_your-cartesia-key-here  # For low-latency TTS

# LiveKit (Required for voice agent)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# SIP / Phone (Telnyx via LiveKit)
# Get this from LiveKit Cloud dashboard after configuring Telnyx trunk
SIP_OUTBOUND_TRUNK_ID=ST_your-sip-trunk-id-here

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
